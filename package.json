{
  "name": "stripfeed",
  "version": "1.0.1",
  "description": "Official TypeScript SDK for StripFeed - convert any URL to clean Markdown",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
