    "ai",
    "llm",
    "rag",
    "readability",
    "html-to-markdown",
    "api",
    "sdk"
  ],
  "author": "StripFeed",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/StripFeed/stripfeed-js.git"
  },
  "homepage": "https://www.stripfeed.dev",
  "bugs": {
    "url": "https://github.com/StripFeed/stripfeed-js/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
